@model List<controllermvc.Models.Note>

<h2 style="text-align:center; margin-bottom:20px;">Notlar</h2>

<a asp-action="Create" style="display:inline-block; margin-bottom:20px; padding:8px 12px; background-color:#4CAF50; color:white; text-decoration:none; border-radius:5px;">➕ Yeni Not Ekle</a>

<div style="display:flex; flex-wrap:wrap; gap:20px;">
    @foreach (var item in Model)
    {
        <div style="flex:1 1 calc(33% - 20px); background-color:#fff; padding:15px; border-radius:10px; box-shadow:0 4px 8px rgba(0,0,0,0.1); position:relative;">
            <h3 style="margin-top:0;">@item.Title</h3>
            <p>@item.Content</p>
            <small style="color:#666;">@item.CreatedDate.ToString("dd/MM/yyyy")</small>
            <div style="position:absolute; top:10px; right:10px;">
                <a asp-action="Edit" asp-route-id="@item.Id" title="Düzenle" style="margin-right:8px; color:#2196F3; text-decoration:none; font-weight:bold;">✏️</a>
                <a asp-action="Delete" asp-route-id="@item.Id" title="Sil" style="color:#f44336; text-decoration:none; font-weight:bold;">➖</a>
            </div>
        </div>
    }
</div>