@model List<controllermvc.Models.Note>

<h2 style="text-align:center; margin-bottom:20px;">Notlar</h2>

<a asp-action="Create" style="display:inline-block; margin-bottom:15px; padding:8px 12px; background-color:#4CAF50; color:white; text-decoration:none; border-radius:5px;">➕ Yeni Not Ekle</a>

<table style="width:100%; border-collapse:collapse; box-shadow:0 0 10px rgba(0,0,0,0.1);">
    <thead style="background-color:#f2f2f2;">
        <tr>
            <th style="padding:10px; text-align:left;">Başlık</th>
            <th style="padding:10px; text-align:left;">İçerik</th>
            <th style="padding:10px; text-align:left;">Tarih</th>
            <th style="padding:10px; text-align:center;">İşlem</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr style="border-bottom:1px solid #ddd;">
            <td style="padding:10px;">@item.Title</td>
            <td style="padding:10px;">@item.Content</td>
            <td style="padding:10px;">@item.CreatedDate.ToString("dd/MM/yyyy")</td>
            <td style="padding:10px; text-align:center;">
                <a asp-action="Edit" asp-route-id="@item.Id" title="Düzenle" style="margin-right:10px; color:#2196F3; text-decoration:none; font-weight:bold;">✏️</a>
                <a asp-action="Delete" asp-route-id="@item.Id" title="Sil" style="color:#f44336; text-decoration:none; font-weight:bold;">➖</a>
            </td>
        </tr>
    }
    </tbody>
</table>